{
    "name": "playcanvas",
    "displayName": "PlayCanvas",
    "version": "1.11.3",
    "description": "PlayCanvas Editor VS Code Extension",
    "categories": [
        "Other"
    ],
    "bugs": {
        "url": "https://github.com/playcanvas/vscode-extension/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/playcanvas/vscode-extension.git"
    },
    "license": "MIT",
    "author": "PlayCanvas",
    "publisher": "PlayCanvas",
    "type": "commonjs",
    "main": "./out/extension.js",
    "browser": "./out/browser.js",
    "scripts": {
        "build": "node ./scripts/build.mjs",
        "compile": "tsc -p . && node ./scripts/playcanvas-dts.mjs",
        "compile:plugin": "tsc -p ./plugin",
        "compile:web": "rollup -c",
        "lint": "prettier --check . && eslint .",
        "lint:fix": "prettier --write . && eslint --fix .",
        "pretest": "tsc -p tsconfig.test.json && node ./scripts/vscode-storage.mjs",
        "test": "vscode-test",
        "test:web": "vscode-test-web --extensionDevelopmentPath=.",
        "watch": "tsc -watch -p ./",
        "watch:plugin": "tsc -watch -p ./plugin",
        "watch:web": "rollup -c -w"
    },
    "contributes": {
        "languages": [
            {
                "id": "pcignore",
                "filenames": [
                    ".pcignore"
                ],
                "icon": {
                    "light": "./resources/logo.svg",
                    "dark": "./resources/logo.svg"
                }
            }
        ],
        "configuration": {
            "type": "object",
            "title": "PlayCanvas",
            "properties": {
                "playcanvas.rootDir": {
                    "type": "string",
                    "default": "",
                    "description": "Specify the root directory for PlayCanvas projects (non-web extension only). Leave empty to use the default directory."
                }
            }
        },
        "commands": [
            {
                "command": "playcanvas.login",
                "title": "PlayCanvas: Login"
            },
            {
                "command": "playcanvas.logout",
                "title": "PlayCanvas: Logout"
            },
            {
                "command": "playcanvas.openProject",
                "title": "PlayCanvas: Open Project"
            },
            {
                "command": "playcanvas.reloadProject",
                "title": "PlayCanvas: Reload Project"
            },
            {
                "command": "playcanvas.switchBranch",
                "title": "PlayCanvas: Switch Branch"
            },
            {
                "command": "playcanvas.showPathCollisions",
                "title": "PlayCanvas: Show Path Collisions"
            },
            {
                "command": "playcanvas.reportIssue",
                "title": "PlayCanvas: Report Issue"
            },
            {
                "command": "playcanvas.undo",
                "title": "PlayCanvas: Undo"
            },
            {
                "command": "playcanvas.redo",
                "title": "PlayCanvas: Redo"
            }
        ],
        "keybindings": [
            {
                "command": "playcanvas.undo",
                "key": "ctrl+z",
                "mac": "cmd+z",
                "when": "playcanvas.active && textInputFocus && !editorReadonly"
            },
            {
                "command": "playcanvas.redo",
                "key": "ctrl+shift+z",
                "mac": "cmd+shift+z",
                "when": "playcanvas.active && textInputFocus && !editorReadonly"
            },
            {
                "command": "playcanvas.redo",
                "key": "ctrl+y",
                "when": "playcanvas.active && textInputFocus && !editorReadonly && !isMac"
            }
        ],
        "typescriptServerPlugins": [
            {
                "name": "playcanvas-plugin",
                "enableForWorkspaceTypeScriptVersions": true
            }
        ],
        "colors": [
            {
                "id": "playcanvas.managedForeground",
                "description": "Color for extension-managed files in the explorer",
                "defaults": {
                    "dark": "#8a8a8a",
                    "light": "#6b6b6b",
                    "highContrast": "#8a8a8a",
                    "highContrastLight": "#6b6b6b"
                }
            },
            {
                "id": "playcanvas.dirtyForeground",
                "description": "Color for unsaved files in the explorer",
                "defaults": {
                    "dark": "#f4a62a",
                    "light": "#c88520",
                    "highContrast": "#f4a62a",
                    "highContrastLight": "#c88520"
                }
            }
        ],
        "views": {
            "explorer": [
                {
                    "id": "collab-view",
                    "name": "Collaborators",
                    "icon": "organization",
                    "when": "resourceDirname =~ /playcanvas/"
                }
            ]
        }
    },
    "activationEvents": [
        "onStartupFinished"
    ],
    "dependencies": {
        "@sentry/browser": "^10.49.0",
        "ignore": "^7.0.5",
        "isomorphic-ws": "^5.0.0",
        "ot-text": "github:playcanvas/ot-text",
        "playcanvas-plugin": "file:plugin",
        "sharedb": "3.2.1",
        "ws": "^8.18.3"
    },
    "devDependencies": {
        "@playcanvas/eslint-config": "3.0.0-beta.5",
        "@rollup/plugin-commonjs": "29.0.2",
        "@rollup/plugin-json": "6.1.0",
        "@rollup/plugin-node-resolve": "16.0.3",
        "@rollup/plugin-replace": "6.0.3",
        "@rollup/plugin-swc": "0.4.0",
        "@types/express": "5.0.6",
        "@types/mocha": "10.0.10",
        "@types/node": "22.19.17",
        "@types/sharedb": "3.2.1",
        "@types/sinon": "21.0.1",
        "@types/vscode": "^1.98.0",
        "@types/ws": "8.18.1",
        "@vscode/test-cli": "0.0.12",
        "@vscode/test-electron": "2.5.2",
        "@vscode/test-web": "0.0.80",
        "dotenv": "17.4.2",
        "eslint": "9.39.4",
        "playcanvas": "2.18.1",
        "prettier": "3.8.3",
        "rollup": "4.60.2",
        "rollup-plugin-polyfill-node": "0.13.0",
        "sinon": "21.1.2",
        "typescript": "6.0.3"
    },
    "engines": {
        "vscode": "^1.98.0"
    },
    "icon": "resources/logo.png"
}
